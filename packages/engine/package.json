{
  "name": "@game-engine-canvas/engine",
  "version": "0.1.0",
  "description": "A modular JavaScript 2D game engine built around ECS.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c && tsc -p tsconfig.types.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.1.2",
    "rollup": "^4.44.0",
    "tslib": "^2.8.1",
    "vitest": "^3.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
